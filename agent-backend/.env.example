# Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gateway URL (deployed Flask API gateway)
GATEWAY_URL=https://your-gateway.azurewebsites.net/api/v1

# MCP server absolute path (for agent to spawn MCP subprocess)
MCP_SERVER_PATH=/absolute/path/to/mcp-server/server.py
